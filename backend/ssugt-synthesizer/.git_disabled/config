[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/aklyue/ssugt-synthesizer.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "dev"]
	remote = origin
	merge = refs/heads/dev
	vscode-merge-base = origin/dev
[branch "chore/model-voice-change"]
	vscode-merge-base = origin/dev
	remote = origin
	merge = refs/heads/chore/model-voice-change
